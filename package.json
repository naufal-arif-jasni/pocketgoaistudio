{
  "name": "pocketgo",
  "version": "1.0.0",
  "description": "PocketGo - E-Wallet of SMK Setia Alam. Track spending, top up, and manage student school cards.",
  "main": "dist/server.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2"
  }
}
